<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.attius.homefrontalert">

    <!-- REQUIRED PERMISSIONS FOR LIFE-SAVING BACKGROUND EXECUTION -->
    
    <!-- Required to connect to Firebase and the Unofficial API -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Required to keep the CPU awake while we synthesize audio -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Location Permissions so our App knows where you are locally -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Needed to track location if the screen is fully locked/dozing long-term -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Required for the "Hybrid" Fallback Route (Silent Audio Polling) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Android 13+ requirement for Foreground Notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Optional: Override silent mode for critical alarm stream -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:label="Home Front Alerts"
        android:icon="@drawable/app_icon"
        android:roundIcon="@drawable/app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.PikudAlert">
        
        <!-- Standard Main App Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:label="Advanced Settings"
            android:exported="false" />

        <activity
            android:name=".TOSActivity"
            android:label="Terms of Conditions"
            android:theme="@style/Theme.PikudAlert"
            android:exported="false" />

        <!-- 
             THIS IS THE CRITICAL COMPONENT: 
             It hooks our Kotlin FCM logic blindly into Android's core messaging broadcast system.
        -->
        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- 
             We'll eventually need this service declared to run the "Hybrid Polling" 
             when the user decides they don't trust Firebase latency!
        -->
        <service
            android:name=".LocalPollingService"
            android:foregroundServiceType="location"
            android:exported="false" />

        <!-- Desktop Widget -->
        <receiver android:name=".StatusWidgetProvider" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

    </application>

</manifest>
