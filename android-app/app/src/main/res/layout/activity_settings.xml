<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:scaleType="fitCenter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvSettingsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:alpha="0.9"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp"
            android:orientation="vertical">

            <!-- ── LIVE GPS TOGGLE ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1E1E1E"
                android:elevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/ivGpsIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_gps_antenna"
                        android:tint="#34C759"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/mode_gps"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />
                    <Switch
                        android:id="@+id/switchLiveGps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>



            <!-- ── CURRENT ZONE STATUS ── -->
            <TextView
                android:id="@+id/tvResolvedZone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current Zone: Detecting..."
                android:textColor="#FFEB3B"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- ── MANUAL ZONE HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:id="@+id/ivManualIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_manual_location"
                    android:tint="#546E7A"
                    android:layout_marginEnd="8dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/set_home_zone"
                    android:textStyle="bold"
                    android:textColor="#808080"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ── ZONE SEARCH ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardManualZone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1E1E1E">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical">
                    <AutoCompleteTextView
                        android:id="@+id/autoCompleteZoneSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/search_hint"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#606060"
                        android:completionThreshold="1"
                        android:backgroundTint="#4CAF50"
                        android:textSize="16sp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/search_subtext"
                        android:textColor="#606060"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── LANGUAGE SELECTION ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1E1E1E"
                android:elevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/language_selection"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp" />
                    <RadioGroup
                        android:id="@+id/rgLanguageSettings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RadioButton
                            android:id="@+id/rbEnglishSettings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="English"
                            android:textColor="#FFFFFF"
                            android:buttonTint="#4CAF50" />
                        <RadioButton
                            android:id="@+id/rbHebrewSettings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="עברית"
                            android:textColor="#FFFFFF"
                            android:buttonTint="#4CAF50"
                            android:layout_marginStart="24dp" />
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardAlertSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1A1A1A"
                android:elevation="4dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/connectivity_shield_title"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tvConnectivityDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="..."
                        android:textColor="#FFD60A"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/connectivity_shield_warning"
                        android:textColor="#808080"
                        android:textSize="11sp"
                        android:layout_marginBottom="16dp" />
                    <RadioGroup
                        android:id="@+id/rgConnectivityMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        
                        <!-- Mode: AUTO -->
                        <RadioButton
                            android:id="@+id/rbModeAuto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_auto"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:buttonTint="#4CAF50" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_auto_sub"
                            android:textColor="#606060"
                            android:textSize="10sp"
                            android:layout_marginStart="32dp"
                            android:layout_marginBottom="12dp" />

                        <!-- Mode: DIRECT -->
                        <RadioButton
                            android:id="@+id/rbModeDirect"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_direct"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:buttonTint="#4CAF50" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_direct_sub"
                            android:textColor="#606060"
                            android:textSize="10sp"
                            android:layout_marginStart="32dp"
                            android:layout_marginBottom="12dp" />

                        <!-- Mode: CLOUD -->
                        <RadioButton
                            android:id="@+id/rbModeCloud"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_cloud"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:buttonTint="#4CAF50" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_cloud_sub"
                            android:textColor="#606060"
                            android:textSize="10sp"
                            android:layout_marginStart="32dp" />
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ADVANCED TOGGLE ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_toggle"
                    android:textColor="#606060"
                    android:textSize="12sp" />
                <Switch
                    android:id="@+id/switchShowAdvanced"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- ── ADVANCED SECTION (hidden by default) ── -->
            <LinearLayout
                android:id="@+id/layoutAdvancedSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- ── SOUND TEST (moved to diagnostics) ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSoundTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="#1A1A1A"
                    android:elevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Sound Lab Diagnostics"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:layout_marginBottom="2dp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Test alert synthesis density and timing"
                            android:textColor="#555566"
                            android:textSize="10sp"
                            android:layout_marginBottom="14dp" />

                        <!-- CALM -->
                        <Button
                            android:id="@+id/btnTestCalm"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="🟢 All Clear"
                            android:textColor="#CCFFD0"
                            android:textSize="11sp"
                            android:backgroundTint="#0E3020"
                            android:layout_marginBottom="8dp" />

                        <!-- CAUTION pair -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <Button
                                android:id="@+id/btnTestCautionRemote"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="🟡 Caution Remote"
                                android:textColor="#FFE5A0"
                                android:textSize="9sp"
                                android:backgroundTint="#2E2000"
                                android:layout_marginEnd="4dp" />
                            <Button
                                android:id="@+id/btnTestCautionLocal"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="🟠 Caution Local"
                                android:textColor="#FFD0A0"
                                android:textSize="9sp"
                                android:backgroundTint="#2E1200"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>

                        <!-- URGENT trio -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <Button
                                android:id="@+id/btnTestUrgentSmall"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="🔴 4 zones"
                                android:textColor="#FFB0B0"
                                android:textSize="9sp"
                                android:backgroundTint="#2A0800"
                                android:layout_marginEnd="2dp" />
                            <Button
                                android:id="@+id/btnTestUrgentMed"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="🔴 100 zones"
                                android:textColor="#FFB0B0"
                                android:textSize="9sp"
                                android:backgroundTint="#2A0800"
                                android:layout_marginStart="2dp"
                                android:layout_marginEnd="2dp" />
                            <Button
                                android:id="@+id/btnTestUrgentLarge"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="🔴 600 zones"
                                android:textColor="#FFB0B0"
                                android:textSize="9sp"
                                android:backgroundTint="#2A0800"
                                android:layout_marginStart="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                <!-- ── ALERT LOGIC (SMART DEDUPLICATION) ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="#1A1A1A"
                    android:elevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Smart Sync Deduplication"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:layout_marginBottom="2dp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Prevents redundant beeps for sequential HFC alerts in the same area."
                            android:textColor="#555566"
                            android:textSize="10sp"
                            android:layout_marginBottom="14dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Area Wait Time (Alert TTL)"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp" />
                            <EditText
                                android:id="@+id/etAlertTtl"
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:hint="180"
                                android:inputType="number"
                                android:text="180"
                                android:textColor="#34C759"
                                android:textColorHint="#444444"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:backgroundTint="#34C759" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="sec"
                                android:textColor="#606060"
                                android:textSize="10sp"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>



                <!-- CARD B: SYSTEM DIAGNOSTICS (unified) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="#1E1E1E"
                    android:elevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="System Diagnostics"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:layout_marginBottom="12dp" />

                        <Button
                            android:id="@+id/btnCheckConnection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Run Connection Check"
                            android:backgroundTint="#2196F3" />

                        <TextView
                            android:id="@+id/tvBackendStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Status: Ready"
                            android:textColor="#808080"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="12dp" />

                        <!-- FCM Inbound Log -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#000000"
                            android:padding="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="RECENT FCM INBOUND:"
                                android:textColor="#FF69B4"
                                android:textSize="10sp"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/tvFcmHistory"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Waiting for FCM..."
                                android:textColor="#FF69B4"
                                android:textSize="10sp"
                                android:fontFamily="monospace" />
                        </LinearLayout>

                        <!-- HFC Polling Log -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#000000"
                            android:padding="8dp"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/diag_polling_log"
                                android:textColor="#00FF00"
                                android:textSize="10sp"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/tvHybridLog"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/waiting_service"
                                android:textColor="#00FF00"
                                android:textSize="10sp"
                                android:fontFamily="monospace" />
                            <TextView
                                android:id="@+id/tvLastSync"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Last Success: Never"
                                android:textColor="#4CAF50"
                                android:textSize="10sp"
                                android:fontFamily="monospace"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Baseline Samples -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#000000"
                            android:padding="8dp"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/diag_baseline"
                                android:textColor="#FFEB3B"
                                android:textSize="10sp"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/tvEmptySample"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/no_baseline"
                                android:textColor="#FFEB3B"
                                android:textSize="10sp"
                                android:fontFamily="monospace" />
                        </LinearLayout>

                        <!-- Alert Raw History -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#000000"
                            android:padding="8dp"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/diag_anomalies"
                                android:textColor="#00FFFF"
                                android:textSize="10sp"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/tvRawHistory"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/scanning_packets"
                                android:textColor="#00FFFF"
                                android:textSize="10sp"
                                android:fontFamily="monospace" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- CARD C: DIRECT HFC SHIELD (Standard only — hidden for Pro via code) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardShield"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="#3A1C1C"
                    android:elevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/connectivity_shield_title"
                                android:textStyle="bold"
                                android:textColor="#FF5252"
                                android:textSize="16sp" />
                            <Switch
                                android:id="@+id/switchHybridMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="false" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/connectivity_shield_warning"
                            android:textColor="#FFCDD2"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout> <!-- End Advanced Section -->

            <!-- ── VERSION FOOTER ── -->
            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="v1.7.5"
                android:textColor="#444444"
                android:textSize="11sp"
                android:textAlignment="center"
                android:fontFamily="monospace"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
