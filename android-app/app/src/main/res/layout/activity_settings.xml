<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp">
 
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:scaleType="fitCenter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Back" />
 
        <TextView
            android:id="@+id/tvSettingsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:alpha="0.9"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp">
         
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp"
            android:orientation="vertical">

            <!-- Live GPS Toggle -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1E1E1E"
                android:elevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivGpsIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_gps_antenna"
                        android:tint="#34C759"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/mode_gps"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                    <Switch
                        android:id="@+id/switchLiveGps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Volume & Sound Profile -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1E1E1E"
                android:elevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/master_volume"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <SeekBar
                            android:id="@+id/seekVolume"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="100" />
                        <Button
                            android:id="@+id/btnTestSound"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="BEEP"
                            android:textSize="10sp"
                            android:padding="0dp"
                            android:backgroundTint="#FF9800" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvResolvedZone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current Zone: Detecting..."
                android:textColor="#FFEB3B"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:id="@+id/ivManualIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_manual_location"
                    android:tint="#546E7A"
                    android:layout_marginEnd="8dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/set_home_zone"
                    android:textStyle="bold"
                    android:textColor="#808080"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardManualZone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1E1E1E">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical">
                    
                    <AutoCompleteTextView
                        android:id="@+id/autoCompleteZoneSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/search_hint"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#606060"
                        android:completionThreshold="1"
                        android:backgroundTint="#4CAF50"
                        android:textSize="16sp" />
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/search_subtext"
                        android:textColor="#606060"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>



            <!-- Language Selection (Always Visible) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1E1E1E"
                android:elevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/language_selection"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp" />
                    <RadioGroup
                        android:id="@+id/rgLanguageSettings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RadioButton
                            android:id="@+id/rbEnglishSettings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="English"
                            android:textColor="#FFFFFF"
                            android:buttonTint="#4CAF50" />
                        <RadioButton
                            android:id="@+id/rbHebrewSettings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="עברית"
                            android:textColor="#FFFFFF"
                            android:buttonTint="#4CAF50"
                            android:layout_marginStart="24dp" />
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ALERT SOURCE SELECTOR (PRO ONLY — shown/hidden in SettingsActivity) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAlertSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1A2A1A"
                android:elevation="4dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Alert Source"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Backend (FCM) is instant and battery-efficient. Direct HFC polls the official feed every 2s from your device."
                        android:textColor="#808080"
                        android:textSize="11sp"
                        android:layout_marginBottom="12dp" />
                    <RadioGroup
                        android:id="@+id/rgAlertSource"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton
                            android:id="@+id/rbSourceFcm"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="⚡ Backend (FCM)  — server push, instant"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:buttonTint="#4CAF50"
                            android:layout_marginBottom="6dp" />
                        <RadioButton
                            android:id="@+id/rbSourceDirectHfc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="📡 Direct HFC  — 2s polling, your network"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:buttonTint="#4CAF50" />
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ADVANCED TOGGLE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_toggle"
                    android:textColor="#606060"
                    android:textSize="12sp" />
                <Switch
                    android:id="@+id/switchShowAdvanced"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- ADVANCED SECTION (Hidden by default) -->
            <LinearLayout
                android:id="@+id/layoutAdvancedSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Distance Sound Tester (Advanced tuning) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="#1E1E1E">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvDistTestLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Simulate Distance: 50km"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <SeekBar
                                android:id="@+id/seekDistTest"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:max="500"
                                android:progress="50" />
                            <Button
                                android:id="@+id/btnTestDistSound"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="TEST"
                                android:textSize="10sp"
                                android:backgroundTint="#2196F3" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <Button
                                android:id="@+id/btnTestCaution"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:text="PRE-WARN"
                                android:textSize="10sp"
                                android:backgroundTint="#FFC107"
                                android:layout_marginEnd="4dp" />
                            <Button
                                android:id="@+id/btnTestCalm"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:text="ALL CLEAR"
                                android:textSize="10sp"
                                android:backgroundTint="#4CAF50" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#000000"
                            android:padding="8dp"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="RECENT FCM INBOUND:"
                                android:textColor="#FF69B4"
                                android:textSize="10sp"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/tvFcmHistory"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Waiting for FCM..."
                                android:textColor="#FF69B4"
                                android:textSize="10sp"
                                android:fontFamily="monospace" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            <!-- Backend Status Check -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1E1E1E"
                android:elevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="System Connectivity"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnCheckConnection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Run Unified Connection Check"
                        android:backgroundTint="#2196F3" />

                    <TextView
                        android:id="@+id/tvBackendStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status: Ready"
                        android:textColor="#808080"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginTop="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- HYBRID POLLING TOGGLE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#3A1C1C"
                android:elevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/connectivity_shield_title"
                            android:textStyle="bold"
                            android:textColor="#FF5252"
                            android:textSize="18sp" />

                        <Switch
                            android:id="@+id/switchHybridMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/connectivity_shield_warning"
                        android:textColor="#FFCDD2"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#000000"
                        android:padding="8dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/diag_polling_log"
                            android:textColor="#00FF00"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:id="@+id/tvHybridLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/waiting_service"
                            android:textColor="#00FF00"
                            android:textSize="10sp"
                            android:fontFamily="monospace" />
                        <TextView
                            android:id="@+id/tvLastSync"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Last Success: Never"
                            android:textColor="#4CAF50"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#000000"
                        android:padding="8dp"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/diag_baseline"
                            android:textColor="#FFEB3B"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:id="@+id/tvEmptySample"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/no_baseline"
                            android:textColor="#FFEB3B"
                            android:textSize="10sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#000000"
                        android:padding="8dp"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/diag_anomalies"
                            android:textColor="#00FFFF"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:id="@+id/tvRawHistory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/scanning_packets"
                            android:textColor="#00FFFF"
                            android:textSize="10sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout> <!-- End of Advanced Section -->

            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="v1.6.0"
                android:textColor="#444444"
                android:textSize="11sp"
                android:textAlignment="center"
                android:fontFamily="monospace"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
