<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tvTOSTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tos_title"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/language_selection"
        android:textColor="#808080"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rgLanguage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <RadioButton
            android:id="@+id/rbEnglish"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="English"
            android:textColor="#FFFFFF"
            android:checked="true" />
        <RadioButton
            android:id="@+id/rbHebrew"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="עברית"
            android:textColor="#FFFFFF"
            android:layout_marginStart="16dp" />
    </RadioGroup>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="24dp"
        android:background="#1E1E1E"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTOS"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:paddingBottom="24dp" />
    </ScrollView>

    <Button
        android:id="@+id/btnAcceptTOS"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tos_agree"
        android:layout_marginTop="24dp"
        android:backgroundTint="#FF5252"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/tvTOSSubtext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tos_subtext"
        android:textColor="#888888"
        android:textSize="10sp"
        android:textAlignment="center"
        android:layout_marginTop="12dp" />

</LinearLayout>
