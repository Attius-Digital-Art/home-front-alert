<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Central Content Guideline for max-width simulation -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guidelineStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.0" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guidelineEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="1.0" />

            <!-- Adaptive Main Dashboard Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:backgroundTint="#1E1E1E"
                app:cardElevation="10dp"
                app:cardCornerRadius="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="@id/guidelineStart"
                app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
                app:layout_constraintWidth_max="550dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutDashboardContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <FrameLayout
                        android:id="@+id/ivShieldContainer"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <View
                            android:id="@+id/vStatusRing"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:drawable/presence_online"
                            android:alpha="0.2" />
                        <ImageView
                            android:id="@+id/ivShield"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/app_icon"
                            android:scaleType="fitCenter" />
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/layoutDashboardText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_marginEnd="16dp"
                        android:orientation="vertical"
                        app:layout_constraintStart_toEndOf="@id/ivShieldContainer"
                        app:layout_constraintEnd_toStartOf="@id/vStatusDot"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/current_status_label"
                            android:textColor="#808080"
                            android:textSize="11sp"
                            android:letterSpacing="0.05"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvDashStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no_alerts"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textAllCaps="true" />
                        <TextView
                            android:id="@+id/tvDashTimer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#B0B0B0"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />
                        
                        <!-- Local Countdown Timer (Shown only when local threat is active) -->
                        <TextView
                            android:id="@+id/tvDashCountdown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:15"
                            android:textColor="#FFC107"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            android:layout_marginTop="4dp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tvRecentAlertsSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFA726"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/ivLocationStatus"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_gps_antenna"
                                android:tint="#34C759"
                                android:alpha="0.8" />
                            <TextView
                                android:id="@+id/tvLocationBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:visibility="gone" />
                            <TextView
                                android:id="@+id/tvLocationZone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="..."
                                android:textColor="#B0B0B0"
                                android:textSize="11sp"
                                android:singleLine="true"
                                android:ellipsize="end" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:id="@+id/vStatusDot"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@android:drawable/presence_online"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Adaptive Alert History Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLastAlert"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="#1A1A1A"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:layout_constraintTop_toBottomOf="@id/cardDashboard"
                app:layout_constraintStart_toStartOf="@id/guidelineStart"
                app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
                app:layout_constraintWidth_max="550dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">
                    
                    <TextView
                        android:id="@+id/tvLastThreatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/last_detected_label"
                        android:textColor="#FF9800"
                        android:textSize="10sp"
                        android:letterSpacing="0.05"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvLastAlertInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Distance + Time"
                        android:textColor="#B0B0B0"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvLastAlertZones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Zone Info"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bottom Disclaimer / Space Filler -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:orientation="vertical"
                android:gravity="center"
                android:alpha="0.5"
                app:layout_constraintTop_toBottomOf="@id/cardLastAlert"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/guidelineStart"
                app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
                app:layout_constraintWidth_max="550dp"
                app:layout_constraintVertical_bias="0.1">
                <TextView
                    android:id="@+id/tvFooterLine1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/footer_line1"
                    android:textColor="#B0B0B0"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvFooterLine2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/footer_line2"
                    android:textColor="#808080"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</FrameLayout>
