<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp">

    <!-- Icon/Status Indicator -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp">
        <ImageView
            android:id="@+id/widget_status_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/presence_online"
            android:alpha="0.2" />
        <ImageView
            android:id="@+id/widget_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/app_icon"
            android:padding="4dp" />
    </FrameLayout>

    <!-- Text Information (Will be hidden when resized to 1x1) -->
    <LinearLayout
        android:id="@+id/widget_text_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        
        <TextView
            android:id="@+id/widget_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NO ALERTS"
            android:textColor="#34C759"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
            
        <TextView
            android:id="@+id/widget_zone_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detecting zone..."
            android:textColor="#B0B0B0"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
