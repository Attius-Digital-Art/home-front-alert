<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:padding="8dp">

    <!-- Top Row (Always visible unless extremely small, then just icon) -->
    <LinearLayout
        android:id="@+id/widget_top_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <!-- Icon/Status Indicator -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp">
            <ImageView
                android:id="@+id/widget_status_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/presence_online"
                android:alpha="0.2" />
            <ImageView
                android:id="@+id/widget_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/app_icon"
                android:padding="4dp" />
        </FrameLayout>

        <!-- Text Information (Hidden when resized to 1x1 Small) -->
        <LinearLayout
            android:id="@+id/widget_text_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            
            <TextView
                android:id="@+id/widget_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NO ALERTS"
                android:textColor="#34C759"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="5" />

            <TextView
                android:id="@+id/widget_zone_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detecting zone..."
                android:textColor="#E0E0E0"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4" />
        </LinearLayout>
    </LinearLayout>

    <!-- Mini Log (Visible only when resized to Large/Tall) -->
    <TextView
        android:id="@+id/widget_mini_log"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:text="Recent Threats:\nNo activity in last hour."
        android:textColor="#E0E0E0"
        android:textSize="11sp"
        android:lines="3"
        android:ellipsize="end"
        android:shadowColor="#99000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="4" />

</LinearLayout>
