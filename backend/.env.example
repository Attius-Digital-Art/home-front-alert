# backend/.env.example
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# ── HFC Relay / FCM Dispatcher (index.js) ──────────────────────────────────

# Shared API key required by clients calling the relay endpoints.
API_KEY=your-api-key-here

# Password for the admin dashboard (passed via X-Dashboard-Pass header).
DASHBOARD_PASS=your-dashboard-password

# Firebase service account credentials (used for FCM).
# Option A: paste the full JSON as a single-line string (used in Cloud Run env vars).
# Option B: leave unset and place the file as serviceAccountKey.json in this directory.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# URL of the map-server Cloud Run service (used to proxy map requests).
MAP_SERVICE_URL=https://homefront-map-xxxx-xx.a.run.app

# HTTP port the server listens on.
PORT=8080

# Set automatically by Cloud Run to the service name — leave blank for local dev.
K_SERVICE=

# ── Map Server (map-server.js) ──────────────────────────────────────────────

# URL of the alert relay (homefront-backend) Cloud Run service.
# Used by map-server to fetch live alert data.
BACKEND_SERVICE_URL=https://homefront-backend-xxxx-xx.a.run.app

# Service account for map-server's outbound authenticated requests to the relay.
# Same format as FIREBASE_SERVICE_ACCOUNT above.
RELAY_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
